// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String         @id @default(uuid())
  name           String
  email          String         @unique
  cefrLevel      String         @default("A1")
  streakDays     Int            @default(0)
  lastActiveDate DateTime?
  points         Int            @default(0)
  createdAt      DateTime       @default(now())
  conversations  Conversation[]
  events         StudentEvent[]
  flashcards     Flashcard[]
}

model StudentEvent {
  id        String   @id @default(uuid())
  userId    String
  eventType String   // "grammar_error", "pronunciation_score", "vocabulary_added", "exercise_completed"
  skill     String   // "listening", "speaking", "writing", "grammar", "vocabulary"
  details   String   // JSON stringified details
  score     Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String    @id @default(uuid())
  userId    String
  title     String
  scenario  String    // "casual", "hotel", "interview", "airport"
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
}

model Message {
  id                 String       @id @default(uuid())
  conversationId     String
  role               String       // "user", "assistant"
  content            String
  correctedText      String?
  grammarExplanation String?
  translation        String?
  pronunciationScore Int?
  createdAt          DateTime     @default(now())
  conversation       Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Flashcard {
  id              String   @id @default(uuid())
  userId          String
  word            String
  translation     String
  definition      String
  exampleSentence String
  boxLevel        Int      @default(1)
  nextReviewDate  DateTime @default(now())
  easinessFactor  Float    @default(2.5)
  repetitions     Int      @default(0)
  intervalDays    Int      @default(0)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

